{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "pindropdeploy.vercel.app" }],
      "destination": "https://playpindrop.app/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/daily-post",
      "schedule": "0 10 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/admin",
      "destination": "/api/admin"
    },
    {
      "source": "/omni",
      "destination": "/api/omni"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    },
    {
      "source": "/(icon.*|manifest.json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}